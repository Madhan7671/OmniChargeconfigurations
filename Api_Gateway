server.port=8080

# EUREKA
eureka.client.service-url.defaultZone=http://localhost:8761/eureka/
eureka.instance.prefer-ip-address=true

# AUTH SERVICE
spring.cloud.gateway.server.webmvc.routes[0].id=auth-service
spring.cloud.gateway.server.webmvc.routes[0].uri=lb://USERSERVICE
spring.cloud.gateway.server.webmvc.routes[0].predicates[0]=Path=/auth/**

# ADMIN SERVICE
spring.cloud.gateway.server.webmvc.routes[1].id=admin-service
spring.cloud.gateway.server.webmvc.routes[1].uri=lb://USERSERVICE
spring.cloud.gateway.server.webmvc.routes[1].predicates[0]=Path=/admin/**

# OPERATOR SERVICE
spring.cloud.gateway.server.webmvc.routes[2].id=operator-service
spring.cloud.gateway.server.webmvc.routes[2].uri=lb://OPERATORSERVICE
spring.cloud.gateway.server.webmvc.routes[2].predicates[0]=Path=/operator/**

# RECHARGE SERVICE
spring.cloud.gateway.server.webmvc.routes[3].id=recharge-service
spring.cloud.gateway.server.webmvc.routes[3].uri=lb://RECHARGE-SERVICE
spring.cloud.gateway.server.webmvc.routes[3].predicates[0]=Path=/api/recharges/**

# PAYMENT SERVICE
spring.cloud.gateway.server.webmvc.routes[4].id=payment-service
spring.cloud.gateway.server.webmvc.routes[4].uri=lb://PAYMENTSERVICE
spring.cloud.gateway.server.webmvc.routes[4].predicates[0]=Path=/api/payments/**

# NOTIFICATION SERVICE
spring.cloud.gateway.server.webmvc.routes[5].id=notification-service
spring.cloud.gateway.server.webmvc.routes[5].uri=lb://NOTIFICATIONSERVICE
spring.cloud.gateway.server.webmvc.routes[5].predicates[0]=Path=/api/notifications/**

# GLOBAL CORS
spring.cloud.gateway.server.webmvc.globalcors.cors-configurations.[/**].allowedOrigins=*
spring.cloud.gateway.server.webmvc.globalcors.cors-configurations.[/**].allowedMethods=*
spring.cloud.gateway.server.webmvc.globalcors.cors-configurations.[/**].allowedHeaders=*

# LOGGING
logging.level.org.springframework.cloud.gateway=DEBUG
